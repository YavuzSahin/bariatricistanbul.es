# Bariatric Istanbul - Backend Environment Variables
# Copy this to /home/bariatrices/bariatric-backend/.env

# MongoDB Connection (Use MongoDB Atlas - free tier available)
# Get your connection string from: https://cloud.mongodb.com
MONGO_URL="mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Database name
DB_NAME="bariatric_istanbul"

# CORS - Add your domain(s)
CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# JWT Secret - Generate random string (run: openssl rand -hex 32)
JWT_SECRET="CHANGE_THIS_TO_RANDOM_64_CHAR_STRING"

# Admin credentials for /admin panel
ADMIN_EMAIL="admin@bariatricistanbul.com"
ADMIN_PASSWORD="your-secure-password-here"
